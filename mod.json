{
	"geode": "5.4.1",
	"gd": {
		"win": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081",
		"android": "2.2081"
	},
	"version": "v2.0.0",
	"id": "uproxide.textures",
	"name": "Favorite Mods",
	"developer": "Uproxide",
	"description": "An index for Favorite Mods :)",
	"resources": {
		"spritesheets": {
			"TWSSheet": [
				"resources/TWSSheet/*.png"
			]
		},
		"sprites": [
			"resources/*.png"
		]
	},
	"dependencies": {
		"alphalaneous.happy_textures": {
			"required": true,
			"version": ">=2.1.9"
		},
		"geode.texture-loader": {
			"required": true,
			"version": ">=1.9.0"
		}
	},
	"settings": {
		"cert-verification": {
			"name": "Cert Verification",
			"description": "Enable Cert Verification",
			"type": "bool",
			"default": true
		},

		"version-filter": {
			"name": "Version Filter",
			"description": "Filter TPs to only show TPs that support the current GD Version",
			"type": "bool",
			"default": true
		}
	},
	"tags": [
		"universal", "utility", "interface", "enhancement", "customization"
	],
	"links": {
		"community": "https://discord.gg/uproxide-s-little-land-1204580412299542608",
		"source": "https://github.com/Uproxide/Texture-Workshop"
	}
}
